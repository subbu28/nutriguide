{
  "name": "nutriguide",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:fresh": "lsof -ti:3000 | xargs kill -9 2>/dev/null; vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "start": "./scripts/start-dev.sh",
    "start:all": "./scripts/start-dev.sh",
    "server:dev": "cd server && npm run dev",
    "server:fresh": "cd server && npm run dev:fresh",
    "server:build": "cd server && npm run build",
    "db:push": "cd server && npm run db:push",
    "db:migrate": "cd server && npm run db:migrate"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.95.2",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.23.1",
    "vite": "^6.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.20.0"
  }
}
