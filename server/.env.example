# ===========================================
# BACKEND Environment Variables (Railway)
# ===========================================

# Server
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# Database (PostgreSQL) - Railway will auto-inject this
DATABASE_URL="postgresql://user:password@localhost:5432/nutriguide?schema=public"
# Railway: Use ${{Postgres.DATABASE_URL}} reference

# Authentication (generate secure random strings for production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
COOKIE_SECRET=your-cookie-secret-change-in-production

# CORS - Set to your Vercel frontend URL
CORS_ORIGIN=http://localhost:3000
# Production: CORS_ORIGIN=https://your-app.vercel.app

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_premium_price_id

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Frontend URL - Set to your Vercel frontend URL
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://your-app.vercel.app

# ===========================================
# External Recipe APIs
# ===========================================

# TheMealDB (Free - default)
MEALDB_API_URL=https://www.themealdb.com/api/json/v1/1
MEALDB_API_KEY=1

# Spoonacular (Optional - 150 free calls/day)
# Sign up: https://spoonacular.com/food-api
# SPOONACULAR_API_URL=https://api.spoonacular.com
SPOONACULAR_API_KEY=9b9d605e6e3b4695aeb49641bb2a6ce1

# Edamam (Optional - 10K free calls/month)
# Sign up: https://developer.edamam.com/
# EDAMAM_API_URL=https://api.edamam.com/api/recipes/v2
# EDAMAM_APP_ID=your_app_id
# EDAMAM_APP_KEY=your_app_key

# Tasty via RapidAPI (Optional - 500 free calls/month)
# Sign up: https://rapidapi.com/apidojo/api/tasty
# TASTY_API_URL=https://tasty.p.rapidapi.com
# RAPIDAPI_KEY=your_rapidapi_key
